# BRAIN 2.0 - Example Environment Variables
# Copy this to .env and configure for your setup

# ─────────────────────────────────────────────────────────────────────────────
# Brain Configuration
# ─────────────────────────────────────────────────────────────────────────────
BRAIN_SCALE=0.01

# ─────────────────────────────────────────────────────────────────────────────
# API Configuration  
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8030
ENABLE_CORS=true

# ─────────────────────────────────────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Backend: local_ollama, openai, anthropic, none
LLM_BACKEND=local_ollama

# Local Ollama
OLLAMA_BASE_URL=http://192.168.6.149:9997
OLLAMA_MODELS=qwen2.5:7b,llama3.2:latest,phi3:mini,mistral:latest
LLM_MODEL_INDEX=0
LLM_MODEL_INDEX=0
LLM_PREFER_LOCAL=true

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODELS=gpt-4o-mini,gpt-4o

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# LLM Generation Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=200
LLM_TIMEOUT=120

# ─────────────────────────────────────────────────────────────────────────────
# Cost/Budget Configuration
# ─────────────────────────────────────────────────────────────────────────────
DAILY_BUDGET=0.50
MONTHLY_BUDGET=10.00

# ─────────────────────────────────────────────────────────────────────────────
# Persistence Configuration
# ─────────────────────────────────────────────────────────────────────────────
PERSIST_DIR=brain_state
SAVE_FREQUENCY=10000
AUTO_SAVE=true

# ─────────────────────────────────────────────────────────────────────────────
# Debug
# ─────────────────────────────────────────────────────────────────────────────
DEBUG=false
ENABLE_TELEMETRY=true
