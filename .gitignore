# BRAIN 2.0 - Git Ignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Brain State (persistent runtime data)
brain_state/

# Keep example configs, ignore runtime JSON
*.json
!config.py.example
!*.example.json
!docker-compose*.json

# Kilo internal
.kilo/

# Logs
logs/
*.log

# API Keys / Secrets
.env
.env.local
*.pem
*.key

# Test / Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Temporary files
tmp/
temp/
*.tmp

# Ollama models (large downloads)
~/.ollama/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/package-lock.json

# Docker
docker-compose*.yml
docker-compose*.yaml
*.tar

# OS
Thumbs.db
desktop.ini
